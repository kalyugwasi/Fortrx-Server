# The PUBLIC_BASE_URL is fetched from Infisical and stored in .env.runtime
# Caddy will use this as the site address (e.g., https://yourdomain.duckdns.org)
{$PUBLIC_BASE_URL} {
    encode zstd gzip
    tls {$CADDY_EMAIL}

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy "strict-origin-when-cross-origin"
    }
    @badPaths {
        path /.DS_Store /.env* /.git* /.vscode* /.well-known/phpinfo /phpinfo /phpinfo* /wp-* /wp/* /wordpress/* /xmlrpc.php* /config* /config.json /aws-config.js /aws.config.js /server /server-status* /console* /graphql* /api/graphql* /api/gql* /graphql/api* /v2/_catalog* /telescope* /actuator* /swagger* /swagger-ui.html /swagger.json /v2/api-docs /v3/api-docs /api-docs* /trace.axd /@vite/* /%40vite/* /info.php /debug.php /test.php /i.php /p.php /pi.php /pinfo.php /php.php /wp-config.php*
    }
    @badQuery {
        query rest_route=*
    }
    respond @badPaths 403
    respond @badQuery 403
    # Proxy to the fortrx service on port 8000 and forward the original client address.
    reverse_proxy fortrx:8000 {
        header_up X-Forwarded-For {http.request.remote.host}
        header_up X-Real-IP {http.request.remote.host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
}
